# PIN мастера. Пока можно оставить 2580, позже замените на свой.
MASTER_PIN=2580

# Безопасный переход на Supabase Auth. Оставьте false, пока не выполнена
# миграция supabase/migrations/001_profiles.sql и не добавлены все ключи.
SUPABASE_AUTH_ENABLED=false
VITE_SUPABASE_AUTH_ENABLED=false

# Публичные значения Supabase. ANON key можно использовать во frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Серверные значения Supabase. SERVICE ROLE KEY никогда не добавляйте во frontend.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Используется в ссылках подтверждения email и восстановления пароля.
VITE_PUBLIC_APP_URL=http://127.0.0.1:5173

# Google Таблица с вкладкой "Табаки".
GOOGLE_SHEET_ID=1Fu330axX0aYehTS7mv9EopnzM_4THrxv2d-aR0NQL4o
GOOGLE_SHEET_GID=569579743
GOOGLE_SHEET_NAME=Наличие табаков
GOOGLE_ACTIVE_MIXES_SHEET_NAME=Активные миксы
GOOGLE_MIX_HISTORY_SHEET_NAME=История заказов
GOOGLE_INVENTORY_MOVEMENT_SHEET_NAME=Движение склада

# Для записи в Google Таблицу нужен service account.
# Эти значения должны быть только на backend и не должны попадать во frontend.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Порт локального сервера.
PORT=4173
HOST=127.0.0.1

# Публичный адрес сайта для QR-кодов. Локально можно оставить пустым.
PUBLIC_SITE_URL=
